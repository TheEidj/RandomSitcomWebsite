{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "types": ["node"],
    "outDir": "dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "baseUrl": ".",
    "paths": {
      "@acme/db": ["../../packages/db/src/index.ts"],
      "@acme/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "references": [{ "path": "../../packages/db" }, { "path": "../../packages/shared" }],
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts"]
}
