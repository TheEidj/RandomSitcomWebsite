{
  "name": "@acme/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "DOTENV_CONFIG_PATH=../../.env tsx watch src/server.ts",
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest -c jest.config.cjs"
  },
  "dependencies": {
    "@acme/db": "^0.1.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "argon2": "^0.44.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
